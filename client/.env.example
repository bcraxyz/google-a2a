# Used by hello_apikey_client.py (API token auth)
AGENT_BASE_URL=http://localhost:8080
AGENT_API_TOKEN=your-secret-token-here

# Used by hello_oauth_client.py (OAuth client credentials)
# AGENT_BASE_URL= same as above
OAUTH_ISSUER=https://your-issuer-url         
OAUTH_AUDIENCE=https://your-agent-url or your-client-id
OAUTH_CLIENT_ID=your-client-id
OAUTH_CLIENT_SECRET=your-client-secret
OAUTH_SCOPE=openid profile email offline_access your-client-id/.default

